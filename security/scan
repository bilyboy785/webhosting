#!/bin/bash

# ============================================================
# Security Scanner for /var/www
# Usage: ./scan [options] [directory]
#
# Options:
#   -s <levels>   Severity filter, comma-separated (default: HIGH,MEDIUM,LOW)
#                 Examples: -s HIGH  or  -s HIGH,MEDIUM
#   -r <dest>     SCP destination to push JSON report
#                 Example: -r user@host:/var/reports/
#   -p <port>     SSH port for SCP (default: 22)
#   -i <key>      SSH identity file for SCP
#   -o <path>     Output directory for JSON file (default: /tmp)
#   -h            Show this help
#
# Output file: <outdir>/security.<hostname>
# ============================================================

SEVERITY_FILTER="HIGH,MEDIUM,LOW"
SCP_DEST=""
SCP_PORT="22"
SCP_KEY=""
OUT_DIR="/tmp"
TARGET=""

usage() {
    sed -n '4,16p' "$0" | sed 's/^# \?//'
    exit 0
}

while getopts ":s:r:p:i:o:h" opt; do
    case $opt in
        s) SEVERITY_FILTER="${OPTARG^^}" ;;
        r) SCP_DEST="$OPTARG" ;;
        p) SCP_PORT="$OPTARG" ;;
        i) SCP_KEY="$OPTARG" ;;
        o) OUT_DIR="$OPTARG" ;;
        h) usage ;;
        \?) echo "Unknown option: -$OPTARG"; usage ;;
    esac
done
shift $((OPTIND - 1))

TARGET="${1:-/var/www}"
JSON_FILE="${OUT_DIR}/$(hostname -f).json"

# jq is required for JSON generation
if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
fi

if [ ! -d "$TARGET" ]; then
    echo "Error: directory '$TARGET' not found." >&2
    exit 1
fi

# Accumulators
ISSUES_JSON="[]"
COUNT_HIGH=0
COUNT_MEDIUM=0
COUNT_LOW=0

# ---- helpers ------------------------------------------------

severity_enabled() {
    [[ ",$SEVERITY_FILTER," == *",$1,"* ]]
}

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

log_issue() {
    local severity="$1"
    local category="$2"
    local message="$3"
    local file="$4"

    severity_enabled "$severity" || return 0

    # Append to JSON array
    ISSUES_JSON=$(jq \
        --arg sev "$severity" \
        --arg cat "$category" \
        --arg msg "$message" \
        --arg f   "$file" \
        '. += [{"severity":$sev,"category":$cat,"message":$msg,"file":$f}]' \
        <<< "$ISSUES_JSON")

    case "$severity" in
        HIGH)
            COUNT_HIGH=$((COUNT_HIGH + 1))
            echo -e "${RED}[HIGH]${NC}    [$category] $message"
            ;;
        MEDIUM)
            COUNT_MEDIUM=$((COUNT_MEDIUM + 1))
            echo -e "${YELLOW}[MEDIUM]${NC}  [$category] $message"
            ;;
        LOW)
            COUNT_LOW=$((COUNT_LOW + 1))
            echo -e "${CYAN}[LOW]${NC}     [$category] $message"
            ;;
    esac
    [ -n "$file" ] && echo "           -> $file"
}

section() {
    echo ""
    echo -e "${GREEN}=== $1 ===${NC}"
}

# ---- header -------------------------------------------------

echo "============================================================"
echo " Security Scan: $TARGET"
echo " Host:          $(hostname)"
echo " Date:          $(date)"
echo " Severity:      $SEVERITY_FILTER"
echo "============================================================"

# Directories to exclude from all scans (array for safe find argument expansion)
EXCLUDE_PRUNE=(
    \( -path "*/wp-content/backups-dup-pro" -o -path "*/wp-content/backups-dup-pro/*" \) -prune -o
)

# ------------------------------------------------------------
# 1. SQL DUMPS
# ------------------------------------------------------------
section "SQL dumps"

while IFS= read -r -d '' f; do
    log_issue "HIGH" "SQL_DUMP" "SQL file exposed publicly" "$f"
done < <(find "$TARGET" "${EXCLUDE_PRUNE[@]}" -type f \( -name "*.sql" -o -name "*.sql.gz" \) -print0 2>/dev/null)

# ------------------------------------------------------------
# 2. BACKUP FILES
# ------------------------------------------------------------
section "Backup files"

while IFS= read -r -d '' f; do
    log_issue "HIGH" "BACKUP" "Backup file exposed" "$f"
done < <(find "$TARGET" "${EXCLUDE_PRUNE[@]}" -type f -name "*.bak" -print0 2>/dev/null)

# ------------------------------------------------------------
# 3. ENV FILES
# ------------------------------------------------------------
section "Environment files"

while IFS= read -r -d '' f; do
    log_issue "HIGH" "ENV_FILE" ".env file with potential credentials" "$f"
done < <(find "$TARGET" "${EXCLUDE_PRUNE[@]}" -type f -name ".env*" -print0 2>/dev/null)

# ------------------------------------------------------------
# GENERATE JSON REPORT
# ------------------------------------------------------------
TOTAL=$((COUNT_HIGH + COUNT_MEDIUM + COUNT_LOW))

jq -n \
    --arg  hostname        "$(hostname)" \
    --arg  date            "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg  target          "$TARGET" \
    --arg  severity_filter "$SEVERITY_FILTER" \
    --argjson high         "$COUNT_HIGH" \
    --argjson medium       "$COUNT_MEDIUM" \
    --argjson low          "$COUNT_LOW" \
    --argjson total        "$TOTAL" \
    --argjson issues       "$ISSUES_JSON" \
    '{
        hostname:        $hostname,
        date:            $date,
        target:          $target,
        severity_filter: $severity_filter,
        summary: {
            total:  $total,
            high:   $high,
            medium: $medium,
            low:    $low
        },
        issues: $issues
    }' > "$JSON_FILE"

# ------------------------------------------------------------
# SUMMARY
# ------------------------------------------------------------
echo ""
echo "============================================================"
echo " TOTAL ISSUES: $TOTAL  (HIGH: $COUNT_HIGH  MEDIUM: $COUNT_MEDIUM  LOW: $COUNT_LOW)"
echo " JSON report:  $JSON_FILE"
echo "============================================================"

# ------------------------------------------------------------
# SCP (optional)
# ------------------------------------------------------------
if [ -n "$SCP_DEST" ]; then
    echo ""
    echo "Pushing report to $SCP_DEST ..."
    SCP_OPTS=(-P "$SCP_PORT" -o StrictHostKeyChecking=no)
    [ -n "$SCP_KEY" ] && SCP_OPTS+=(-i "$SCP_KEY")
    if scp "${SCP_OPTS[@]}" "$JSON_FILE" "$SCP_DEST"; then
        echo "Done."
    else
        echo "Error: scp failed (exit $?)." >&2
        exit 2
    fi
fi
